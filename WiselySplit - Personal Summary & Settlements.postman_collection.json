	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"requests": {},
				"exec": [
					"// Calculate last 30 days dates",
					"var now = new Date();",
					"var endDate = now.toISOString().split('T')[0];",
					"var startDate = new Date(now);",
					"startDate.setDate(now.getDate() - 30);",
					"var startDateStr = startDate.toISOString().split('T')[0];",
					"",
					"pm.collectionVariables.set('last_30_days_start', startDateStr);",
					"pm.collectionVariables.set('last_30_days_end', endDate);",
					"",
					"// Set today's date for settlements",
					"pm.collectionVariables.set('settlement_date', endDate);",
					"",
					"// Set default start and end dates (last 30 days)",
					"if (!pm.collectionVariables.get('start_date')) {",
					"    pm.collectionVariables.set('start_date', startDateStr);",
					"}",
					"if (!pm.collectionVariables.get('end_date')) {",
					"    pm.collectionVariables.set('end_date', endDate);",
					"}"
				]
			}
		},
