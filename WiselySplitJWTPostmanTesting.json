{
  "info": {
    "name": "WiselySplit JWT API",
    "_postman_id": "abcd1234-5678-90ef-abcd-1234567890ef",
    "description": "Postman collection for WiselySplit backend with JWT auth (Signup is open, others protected)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup (Register User - Open)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/users",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "users"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Smith\",\n  \"userName\": \"alice123\",\n  \"email\": \"alice@example.com\",\n  \"phoneNum\": 1234567890,\n  \"password\": \"mypassword\",\n  \"profilePicture\": \"https://example.com/pic.png\"\n}"
        }
      }
    },
    {
      "name": "Login (Get JWT - Open)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"mypassword\"\n}"
        }
      }
    },
    {
      "name": "Get User by ID (Protected)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/users/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "users", "1"]
        }
      }
    },
    {
      "name": "Update User (Protected)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/users/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "users", "1"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Updated\",\n  \"userName\": \"alice123\",\n  \"email\": \"alice_new@example.com\",\n  \"phoneNum\": 9876543210,\n  \"password\": \"newpassword\",\n  \"profilePicture\": \"https://example.com/new.png\"\n}"
        }
      }
    },
    {
      "name": "Delete User (Protected)",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/users/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "users", "1"]
        }
      }
    },
    {
      "name": "Password Reset - Request (Open)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/auth/reset/request",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "reset", "request"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"alice@example.com\" }"
        }
      }
    },
    {
      "name": "Password Reset - Verify OTP (Open)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/auth/reset/verify",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "reset", "verify"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"alice@example.com\", \"otp\": \"123456\" }"
        }
      }
    },
    {
      "name": "Password Reset - Confirm (Open)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/auth/reset/confirm",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "auth", "reset", "confirm"]
        },
        "body": {
          "mode": "raw",
          "raw": "{ \"email\": \"alice@example.com\", \"newPassword\": \"freshpassword\" }"
        }
      }
    },
    {
      "name": "Dashboard (Protected)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/dashboard/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "dashboard", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": ""
    }
  ]
}