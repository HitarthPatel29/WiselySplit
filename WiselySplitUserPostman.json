{
  "info": {
    "name": "WiselySplit User API Flow",
    "_postman_id": "e9e67f28-12a4-4f93-9bcf-bd3f0c123abc",
    "description": "Sequential API tests for WiselySplit with variable chaining (userId, authToken, resetToken).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Signup (Create User)",
      "item": [
        {
          "name": "Good - Valid User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"userName\": \"janedoe\",\n  \"email\": \"janedoe@example.com\",\n  \"phoneNum\": \"1234567890\",\n  \"password\": \"Strong@123\",\n  \"profilePicture\": \"\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.userId) {",
                  "  pm.environment.set(\"userId\", json.userId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Bad - Weak Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Weak User\",\n  \"userName\": \"weakuser\",\n  \"email\": \"weak@example.com\",\n  \"phoneNum\": \"1234567890\",\n  \"password\": \"password\",\n  \"profilePicture\": \"\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Login (Get Token)",
      "item": [
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"janedoe@example.com\",\n  \"password\": \"Strong@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set(\"authToken\", json.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Get User by ID",
      "item": [
        {
          "name": "Good - Existing User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Bad - Non-existing User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": "{{baseUrl}}/api/users/9999"
          }
        }
      ]
    },
    {
      "name": "Password Reset Flow",
      "item": [
        {
          "name": "Request Reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset/request",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"janedoe@example.com\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"janedoe@example.com\",\n  \"otp\": \"123456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = pm.response.json();",
                  "if (json.resetToken) {",
                  "  pm.environment.set(\"resetToken\", json.resetToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Confirm Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/reset/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"{{resetToken}}\",\n  \"newPassword\": \"Reset@1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Update User",
      "item": [
        {
          "name": "Good - Valid Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Updated\",\n  \"userName\": \"janedoe\",\n  \"email\": \"janedoe@example.com\",\n  \"phoneNum\": \"1234567890\",\n  \"password\": \"NewStrong@123\",\n  \"profilePicture\": \"\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Delete User",
      "item": [
        {
          "name": "Good - Delete Existing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Bad - Delete Non-existing",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": "{{baseUrl}}/api/users/9999"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userId", "value": "" },
    { "key": "authToken", "value": "" },
    { "key": "resetToken", "value": "" }
  ]
}