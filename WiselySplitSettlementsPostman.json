{
  "info": {
    "name": "WiselySplit - Personal Summary & Settlements",
    "_postman_id": "settlements-1234-5678-90ef-abcd-1234567890ef",
    "description": "Postman collection for Personal Summary, Stripe Settlements, and Manual Settlements features. Includes automatic JWT token management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Get JWT Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) {",
                  "        pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "        console.log('JWT token saved to collection variable');",
                  "    }",
                  "    if (jsonData.userId) {",
                  "        pm.collectionVariables.set('user_id', jsonData.userId);",
                  "        console.log('User ID saved to collection variable');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login to get JWT token. Token is automatically saved to collection variable 'jwt_token'."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints"
    },
    {
      "name": "Personal Summary",
      "item": [
        {
          "name": "Get Personal Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/{{user_id}}/personal-summary?startDate={{start_date}}&endDate={{end_date}}",
              "host": ["{{base_url}}"],
              "path": ["expenses", "{{user_id}}", "personal-summary"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{start_date}}",
                  "description": "Start date in YYYY-MM-DD format"
                },
                {
                  "key": "endDate",
                  "value": "{{end_date}}",
                  "description": "End date in YYYY-MM-DD format"
                }
              ]
            },
            "description": "Get personal summary for a user within a date range. Returns summary with totalLent, totalOwed, and list of expenses."
          },
          "response": []
        },
        {
          "name": "Get Personal Summary - Last 30 Days",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/{{user_id}}/personal-summary?startDate={{last_30_days_start}}&endDate={{last_30_days_end}}",
              "host": ["{{base_url}}"],
              "path": ["expenses", "{{user_id}}", "personal-summary"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{last_30_days_start}}"
                },
                {
                  "key": "endDate",
                  "value": "{{last_30_days_end}}"
                }
              ]
            },
            "description": "Get personal summary for the last 30 days (uses pre-calculated dates)"
          },
          "response": []
        },
        {
          "name": "Get Personal Summary - Custom Date Range",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set custom date range (modify these dates as needed)",
                  "var customStartDate = '2024-01-01';",
                  "var customEndDate = '2024-12-31';",
                  "pm.collectionVariables.set('custom_start_date', customStartDate);",
                  "pm.collectionVariables.set('custom_end_date', customEndDate);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/{{user_id}}/personal-summary?startDate={{custom_start_date}}&endDate={{custom_end_date}}",
              "host": ["{{base_url}}"],
              "path": ["expenses", "{{user_id}}", "personal-summary"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{custom_start_date}}"
                },
                {
                  "key": "endDate",
                  "value": "{{custom_end_date}}"
                }
              ]
            },
            "description": "Get personal summary for a custom date range. Modify the pre-request script to set your dates."
          },
          "response": []
        }
      ],
      "description": "Personal Summary endpoints"
    },
    {
      "name": "Stripe Settlements",
      "item": [
        {
          "name": "Create Stripe Payment Intent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": {{settlement_amount}},\n  \"payerId\": {{user_id}},\n  \"receiverId\": {{receiver_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/intent/create",
              "host": ["{{base_url}}"],
              "path": ["payments", "intent", "create"]
            },
            "description": "Create a Stripe payment intent for settlement. Returns clientSecret, paymentIntentId, and paymentId. Note: Receiver must have a Stripe Connect account."
          },
          "response": []
        },
        {
          "name": "Create Stripe Settlement Expense",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.expenseId) {",
                  "        pm.collectionVariables.set('last_expense_id', jsonData.expenseId);",
                  "        console.log('Expense ID saved: ' + jsonData.expenseId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Settle up with {{receiver_name}}\",\n  \"amount\": {{settlement_amount}},\n  \"date\": \"{{settlement_date}}\",\n  \"type\": \"SettleUp\",\n  \"payerId\": {{user_id}},\n  \"shareWithId\": {{share_with_id}},\n  \"shareWith\": \"{{share_with_name}}\",\n  \"shareWithType\": \"{{share_with_type}}\",\n  \"splitDetails\": [\n    {\n      \"userId\": {{receiver_id}},\n      \"name\": \"{{receiver_name}}\",\n      \"amount\": {{settlement_amount}},\n      \"portion\": 1,\n      \"include\": true\n    }\n  ],\n  \"isSettleUp\": true,\n  \"settlementTargetId\": {{receiver_id}},\n  \"paymentId\": {{payment_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses",
              "host": ["{{base_url}}"],
              "path": ["expenses"]
            },
            "description": "Create a settlement expense record after Stripe payment is successful. Requires paymentId from the payment intent creation."
          },
          "response": []
        },
        {
          "name": "Create Payment Record (for updating settlement)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.paymentId) {",
                  "        pm.collectionVariables.set('payment_id', jsonData.paymentId);",
                  "        console.log('Payment ID saved: ' + jsonData.paymentId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": {{settlement_amount}},\n  \"payerId\": {{user_id}},\n  \"receiverId\": {{receiver_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses/payments",
              "host": ["{{base_url}}"],
              "path": ["expenses", "payments"]
            },
            "description": "Create a payment record. Returns paymentId. Used when updating an existing settlement to add Stripe payment."
          },
          "response": []
        },
        {
          "name": "Get Payment Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/payments/{{payment_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["payments", "{{payment_id}}", "status"]
            },
            "description": "Get the status of a payment by paymentId."
          },
          "response": []
        },
        {
          "name": "Complete Stripe Settlement Flow",
          "item": [
            {
              "name": "Step 1: Create Payment Intent",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "    var jsonData = pm.response.json();",
                      "    if (jsonData.paymentId) {",
                      "        pm.collectionVariables.set('payment_id', jsonData.paymentId);",
                      "    }",
                      "    if (jsonData.clientSecret) {",
                      "        pm.collectionVariables.set('client_secret', jsonData.clientSecret);",
                      "    }",
                      "    if (jsonData.paymentIntentId) {",
                      "        pm.collectionVariables.set('payment_intent_id', jsonData.paymentIntentId);",
                      "    }",
                      "    console.log('Payment Intent created. Payment ID: ' + jsonData.paymentId);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"amount\": {{settlement_amount}},\n  \"payerId\": {{user_id}},\n  \"receiverId\": {{receiver_id}}\n}"
                },
                "url": {
                  "raw": "{{base_url}}/payments/intent/create",
                  "host": ["{{base_url}}"],
                  "path": ["payments", "intent", "create"]
                }
              },
              "response": []
            },
            {
              "name": "Step 2: Create Settlement Expense",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 200 || pm.response.code === 201) {",
                      "    var jsonData = pm.response.json();",
                      "    if (jsonData.expenseId) {",
                      "        pm.collectionVariables.set('last_expense_id', jsonData.expenseId);",
                      "        console.log('Stripe settlement expense created. Expense ID: ' + jsonData.expenseId);",
                      "    }",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"Settle up with {{receiver_name}}\",\n  \"amount\": {{settlement_amount}},\n  \"date\": \"{{settlement_date}}\",\n  \"type\": \"SettleUp\",\n  \"payerId\": {{user_id}},\n  \"shareWithId\": {{share_with_id}},\n  \"shareWith\": \"{{share_with_name}}\",\n  \"shareWithType\": \"{{share_with_type}}\",\n  \"splitDetails\": [\n    {\n      \"userId\": {{receiver_id}},\n      \"name\": \"{{receiver_name}}\",\n      \"amount\": {{settlement_amount}},\n      \"portion\": 1,\n      \"include\": true\n    }\n  ],\n  \"isSettleUp\": true,\n  \"settlementTargetId\": {{receiver_id}},\n  \"paymentId\": {{payment_id}}\n}"
                },
                "url": {
                  "raw": "{{base_url}}/expenses",
                  "host": ["{{base_url}}"],
                  "path": ["expenses"]
                }
              },
              "response": []
            }
          ],
          "description": "Complete flow for creating a Stripe settlement. Run this folder to execute both steps in sequence."
        }
      ],
      "description": "Stripe settlement endpoints"
    },
    {
      "name": "Manual Settlements",
      "item": [
        {
          "name": "Create Manual Settlement",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.expenseId) {",
                  "        pm.collectionVariables.set('last_expense_id', jsonData.expenseId);",
                  "        console.log('Manual settlement created. Expense ID: ' + jsonData.expenseId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Settle up with {{receiver_name}}\",\n  \"amount\": {{settlement_amount}},\n  \"date\": \"{{settlement_date}}\",\n  \"type\": \"SettleUp\",\n  \"payerId\": {{user_id}},\n  \"shareWithId\": {{share_with_id}},\n  \"shareWith\": \"{{share_with_name}}\",\n  \"shareWithType\": \"{{share_with_type}}\",\n  \"splitDetails\": [\n    {\n      \"userId\": {{receiver_id}},\n      \"name\": \"{{receiver_name}}\",\n      \"amount\": {{settlement_amount}},\n      \"portion\": 1,\n      \"include\": true\n    }\n  ],\n  \"isSettleUp\": true,\n  \"settlementTargetId\": {{receiver_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses",
              "host": ["{{base_url}}"],
              "path": ["expenses"]
            },
            "description": "Create a manual settlement (no paymentId). This represents a settlement that was paid outside of Stripe."
          },
          "response": []
        },
        {
          "name": "Update Manual Settlement",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Settle up with {{receiver_name}}\",\n  \"amount\": {{updated_settlement_amount}},\n  \"date\": \"{{settlement_date}}\",\n  \"type\": \"SettleUp\",\n  \"payerId\": {{user_id}},\n  \"shareWithId\": {{share_with_id}},\n  \"shareWith\": \"{{share_with_name}}\",\n  \"shareWithType\": \"{{share_with_type}}\",\n  \"splitDetails\": [\n    {\n      \"userId\": {{receiver_id}},\n      \"name\": \"{{receiver_name}}\",\n      \"amount\": {{updated_settlement_amount}},\n      \"portion\": 1,\n      \"include\": true\n    }\n  ],\n  \"isSettleUp\": true,\n  \"settlementTargetId\": {{receiver_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/expenses/{{expense_id}}",
              "host": ["{{base_url}}"],
              "path": ["expenses", "{{expense_id}}"]
            },
            "description": "Update an existing manual settlement. Note: Stripe settlements cannot be updated."
          },
          "response": []
        },
        {
          "name": "Get Settlement Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/expenses/{{expense_id}}",
              "host": ["{{base_url}}"],
              "path": ["expenses", "{{expense_id}}"]
            },
            "description": "Get details of a specific expense/settlement by expenseId."
          },
          "response": []
        }
      ],
      "description": "Manual settlement endpoints"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Calculate last 30 days dates",
          "var now = new Date();",
          "var endDate = now.toISOString().split('T')[0];",
          "var startDate = new Date(now);",
          "startDate.setDate(now.getDate() - 30);",
          "var startDateStr = startDate.toISOString().split('T')[0];",
          "",
          "pm.collectionVariables.set('last_30_days_start', startDateStr);",
          "pm.collectionVariables.set('last_30_days_end', endDate);",
          "",
          "// Set today's date for settlements",
          "pm.collectionVariables.set('settlement_date', endDate);",
          "",
          "// Set default start and end dates (last 30 days)",
          "if (!pm.collectionVariables.get('start_date')) {",
          "    pm.collectionVariables.set('start_date', startDateStr);",
          "}",
          "if (!pm.collectionVariables.get('end_date')) {",
          "    pm.collectionVariables.set('end_date', endDate);",
          "}"
        ]
      }
    }
  ],
